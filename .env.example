# ── LLM provider ─────────────────────────────────────────────────────────────
# "openai" (default) or "bedrock"
LLM_PROVIDER=openai

# ── OpenAI (when LLM_PROVIDER=openai) ────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ── AWS Bedrock (when LLM_PROVIDER=bedrock) ──────────────────────────────────
# Paste your Bedrock API key here (the bearer token). Region must match where
# you enabled model access. Verify model IDs in the Bedrock console — newer
# Claude models often require the region-prefixed inference-profile ID (us./eu.).
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1
# Use a current inference-profile ID (us./eu. prefix). Verify in the Bedrock
# console; older Claude IDs are gated as "legacy". Titan embeds support on-demand.
BEDROCK_CHAT_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/app.db
# Production (Postgres): DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/aisupport

# ── Vector Store ─────────────────────────────────────────────────────────────
VECTOR_STORE_PATH=./data/faiss_index
VECTOR_STORE_TYPE=faiss
# Production: VECTOR_STORE_TYPE=chroma

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Admin account (seeded on first boot) ─────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# ── Multi-tenancy (Phase 7) ──────────────────────────────────────────────────
DEFAULT_TENANT=default
# JSON map of tenant_id -> API key; widgets exchange the key at POST /auth/token.
TENANT_API_KEYS={"default": "demo-key", "acme": "acme-key"}

# ── Rate limiting (Phase 7) ──────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ── Cost tracking (Phase 7) — USD per 1M tokens (gpt-4o-mini defaults) ────────
PRICE_INPUT_PER_1M=0.15
PRICE_OUTPUT_PER_1M=0.60

# ── Guardrails (Phase 7) ─────────────────────────────────────────────────────
GUARDRAILS_ENABLED=true

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# Tenant the chat widget authenticates as (must match a key in TENANT_API_KEYS)
NEXT_PUBLIC_TENANT_ID=default
NEXT_PUBLIC_TENANT_API_KEY=demo-key
